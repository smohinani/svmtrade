    # Make simple prediction
    next_pivot = predict_next_pivot_simple(wave_data)
    if next_pivot:
        print(f"Simple prediction for next pivot: {next_pivot['predicted_type_name']} with estimated value {next_pivot['estimated_value']:.2f}")
